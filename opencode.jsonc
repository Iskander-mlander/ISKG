{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "pylsp": {
      "command": ["pylsp"],
      "extensions": ["py", "pyw"]
    }
  },
  "formatter": {
    "python": {
      "command": ["ruff", "format", "-"],
      "extensions": ["py", "pyw"]
    }
  },
  "command": {
    "test": {
      "template": "python -m pytest tests/ -q",
      "description": "Run all tests"
    },
    "lint": {
      "template": "python -m ruff check iskg/ tests/",
      "description": "Lint Python with ruff"
    },
    "format": {
      "template": "python -m ruff format iskg/ tests/",
      "description": "Format Python with ruff"
    },
    "checkall": {
      "template": "python -m ruff check iskg/ tests/ && python -m ruff format --check iskg/ tests/",
      "description": "Lint and format check"
    },
    "demo": {
      "template": "python examples/widget_demo.py",
      "description": "Run the ISKG demo application"
    }
  },
  "permission": {
    "bash": "ask",
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow"
  }
}
